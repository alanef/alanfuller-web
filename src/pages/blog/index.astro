---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<Layout title="Blog" description="Thoughts on WordPress development, email marketing, automation, and building software products.">
  <Header />

  <main class="py-16 md:py-24">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-section-title text-[#1e3a8a] mb-4">Blog</h1>
        <p class="text-xl text-gray-600 mb-12">
          Thoughts on WordPress development, email marketing, automation, and building software products.
        </p>

        <div class="space-y-8">
          {posts.map((post) => (
            <article class="border-b border-gray-200 pb-8 last:border-b-0">
              <a href={`/blog/${post.slug}/`} class="group block">
                <time datetime={post.data.pubDate.toISOString()} class="text-sm text-gray-500 mb-2 block">
                  {formatDate(post.data.pubDate)}
                </time>
                <h2 class="text-2xl font-bold text-gray-900 group-hover:text-[#1e3a8a] transition-colors mb-3">
                  {post.data.title}
                </h2>
                <p class="text-gray-600 mb-4">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </article>
          ))}
        </div>

        {posts.length === 0 && (
          <p class="text-gray-600">No posts yet. Check back soon!</p>
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>